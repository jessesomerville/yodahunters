{{define "main"}}
  <main>
    <div class="word-up">
      <p class="word-up-title">What's on your mind?</p>
      <p class="word-up-content">
        I'm thinking in this box we'll have a little user submitted blurb that get's refreshed every so often. 
        We can have people submit as many as they want and load them into a queue or something.
      </p>
    </div>
    <div class="threadbox">
      <p class="threadbox-title-content">
        Da Latest Threads ... ....
      </p>
      <table class="threadbox-table">
        <tr class="threadbox-table-header">
          <th class="threadbox-icon-cell">Icon</th>
          <th class="threadbox-title-cell">Title</th>
          <th class="threadbox-author-cell">Author</th>
          <th>Replies</th>
          <th class="threadbox-rating-cell">Rating</th>
          <th class="threadbox-lastpost-cell">Last Post</th>
        {{range .ThreadViews}}
        </tr>
        <tr class="threadbox-row">
          <td class="threadbox-icon-cell">
            <img class="posticon" src="/static/img/posticons/balls.gif">
          </td>
          <td class="threadbox-title-cell">
            <a href="#">{{.Title}}</a>
          </td>
          <td class="threadbox-author-cell">
            <a href="#">{{.AuthorName}}</a>
          </td>
          <td>
            {{.ReplyCount}}
          </td>
          <td class="threadbox-rating-cell">
            <div class="threadbox-rating-div">
              <img class="rating-star" src="/static/img/star.svg">
            </div>
          </td>
          <td class="threadbox-lastpost-cell">
          <a href="#">{{.LatestComment}}</a>
          </td>
        </tr>
        {{ end }}
      </table>
    </div>
  </main>
{{end}}